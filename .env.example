APP_NAME=DayPlanner
ENVIRONMENT=development
DEBUG=true

DATABASE_NAME=day_planner.db
DATA_FOLDER=data

DEFAULT_TIMEZONE=Asia/Kolkata

# Local dev: set these in .env (never commit .env)
# GCP: upload via ./deploy/create-secrets.sh and set USE_SECRET_MANAGER=true
USE_SECRET_MANAGER=false
GCP_PROJECT_ID=

# Change these before production (local only when USE_SECRET_MANAGER=false)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Telegram — Day Planner blocks
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Telegram — Todos (separate bot)
TODO_TELEGRAM_BOT_TOKEN=
TODO_TELEGRAM_BOT_USERNAME=

# HTTP port (Cloud Run sets PORT automatically)
PORT=8080

# Scheduler mode
# false = bots run notification jobs every SCHEDULER_POLL_SECONDS (local default)
# true  = bots only handle chat; use jobs service + Cloud Scheduler on GCP
USE_CLOUD_SCHEDULER=false
SCHEDULER_POLL_SECONDS=5
SCHEDULER_SECRET=change-me-to-a-long-random-string
JOBS_SERVICE_URL=http://127.0.0.1:8080

# Optional: override default Secret Manager secret ids (GCP only)
# SECRET_ID_TELEGRAM_BOT_TOKEN=day-planner-telegram-bot-token
# SECRET_ID_TODO_TELEGRAM_BOT_TOKEN=day-planner-todo-telegram-bot-token
# SECRET_ID_ADMIN_USERNAME=day-planner-admin-username
# SECRET_ID_ADMIN_PASSWORD=day-planner-admin-password
# SECRET_ID_SCHEDULER_SECRET=day-planner-scheduler-secret
