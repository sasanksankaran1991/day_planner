# Day Planner — production GCP config (dayplannerserver)
# Committed to git — no secrets here (those live in Secret Manager).

GCP_PROJECT_ID=dayplannerserver
GCP_REGION=asia-south1

GCS_DATA_BUCKET=dayplannerserver-dp-data
AR_REPO=day-planner
DP_IMAGE=day-planner

USE_SECRET_MANAGER=true
TZ=Asia/Kolkata

RUNNER_SA=dp-runner
SCHEDULER_SA=dp-scheduler

# Public Streamlit URL (app has its own login)
STREAMLIT_PUBLIC=1
STREAMLIT_MIN_INSTANCES=0

# Legacy setting — background pull disabled in entrypoint; kept for env compat
GCS_SYNC_INTERVAL_SEC=300

# Custom domain
DOMAIN=planner.sasanksankaran.in
DP_STREAMLIT_SERVICE=day-planner-ui
