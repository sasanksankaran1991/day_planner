# Day Planner — production GCP config (dayplannerserver)
# Committed to git — no secrets here (those live in Secret Manager).

GCP_PROJECT_ID=dayplannerserver
GCP_REGION=asia-southeast1

# Singapore bucket (same region as Cloud Run). Old Mumbai bucket: dayplannerserver-dp-data
GCS_DATA_BUCKET=dayplannerserver-dp-data-sg
AR_REPO=day-planner
DP_IMAGE=day-planner

USE_SECRET_MANAGER=true
TZ=Asia/Kolkata

RUNNER_SA=dp-runner
SCHEDULER_SA=dp-scheduler

# Public Streamlit URL (app has its own login)
STREAMLIT_PUBLIC=1
STREAMLIT_MIN_INSTANCES=0

# Legacy setting — periodic pull for Streamlit only (jobs use writer lock queue)
GCS_SYNC_INTERVAL_SEC=300

# DB writer lock queue (seconds): wait up to 10 min, poll every 3s, lock TTL 15 min
GCS_DB_LOCK_WAIT_SEC=600
GCS_DB_LOCK_POLL_SEC=3
GCS_DB_LOCK_TTL_SEC=900
# UI priority: faster poll + jobs defer while UI is waiting to save
GCS_DB_LOCK_UI_POLL_SEC=0.5
GCS_UI_PRIORITY_TTL_SEC=30

# Custom domain
DOMAIN=planner.sasanksankaran.in
DP_STREAMLIT_SERVICE=day-planner-ui
