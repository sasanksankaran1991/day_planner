# Production GCP config — copy of scripts/gcp/config.env (kept for reference).
# After git pull, use scripts/gcp/config.env directly (no copy needed).

GCP_PROJECT_ID=dayplannerserver
GCP_REGION=asia-southeast1

# Use a bucket in GCP_REGION (e.g. dayplannerserver-dp-data-sg for Singapore)
GCS_DATA_BUCKET=dayplannerserver-dp-data-sg
AR_REPO=day-planner
DP_IMAGE=day-planner

USE_SECRET_MANAGER=true
TZ=Asia/Kolkata

RUNNER_SA=dp-runner
SCHEDULER_SA=dp-scheduler

STREAMLIT_PUBLIC=1
STREAMLIT_MIN_INSTANCES=0
GCS_SYNC_INTERVAL_SEC=300
GCS_DB_LOCK_WAIT_SEC=600
GCS_DB_LOCK_POLL_SEC=3
GCS_DB_LOCK_TTL_SEC=900
GCS_DB_LOCK_UI_POLL_SEC=0.5
GCS_UI_PRIORITY_TTL_SEC=30

DOMAIN=planner.sasanksankaran.in
DP_STREAMLIT_SERVICE=day-planner-ui
