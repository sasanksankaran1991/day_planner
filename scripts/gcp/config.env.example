# Copy to scripts/gcp/config.env and edit:
#   cp scripts/gcp/config.env.example scripts/gcp/config.env

GCP_PROJECT_ID=dayplannerserver
GCP_REGION=asia-south1

# GCS bucket for day_planner.db (created by bootstrap)
GCS_DATA_BUCKET=dayplannerserver-dp-data

# Artifact Registry repo name (created by bootstrap)
AR_REPO=day-planner

# Docker image name
DP_IMAGE=day-planner

USE_SECRET_MANAGER=1
TZ=Asia/Kolkata

# Service accounts (created by bootstrap)
RUNNER_SA=dp-runner
SCHEDULER_SA=dp-scheduler

# Streamlit: public URL with app login (required for custom domain)
STREAMLIT_PUBLIC=1
STREAMLIT_MIN_INSTANCES=0
GCS_SYNC_INTERVAL_SEC=300

# Custom domain (optional — run: bash scripts/gcp/map-domain.sh)
# DOMAIN=planner.sasanksankaran.in
